{
  "name": "ouroboros",
  "version": "0.1.0",
  "description": "自指循环 Agent 框架 — 模型 + 提示词 + 工具 + 程序编排",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "ouroboros": "./dist/cli/index.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsx src/cli/index.ts start --cwd .",
    "start": "tsx src/cli/index.ts start",
    "login": "tsx src/cli/index.ts login",
    "configure": "tsx src/cli/index.ts configure",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:phase1": "tsx src/integration/phase1.ts",
    "test:phase2": "tsx src/integration/phase2.ts",
    "test:phase3": "tsx src/integration/phase3.ts",
    "test:phase4": "tsx src/integration/phase4.ts",
    "test:phase5": "tsx src/integration/phase5.ts",
    "test:phase6": "tsx src/integration/phase6.ts",
    "test:phase7": "tsx src/integration/phase7.ts",
    "test:phase8": "tsx src/integration/phase8.ts",
    "test:phase9": "tsx src/integration/phase9.ts",
    "test:phase10": "tsx src/integration/phase10.ts",
    "test:phase11": "tsx src/integration/phase11.ts",
    "test:phase12": "tsx src/integration/phase12.ts",
    "test:all": "tsx src/integration/phase-all.ts",
    "tui": "tsx src/tui/index.ts",
    "lint": "eslint src/",
    "build:web": "cd web && npm run build",
    "build:all": "tsc && cd web && npm run build",
    "format": "prettier --write 'src/**/*.ts' 'tests/**/*.ts'"
  },
  "keywords": [
    "agent",
    "llm",
    "ouroboros"
  ],
  "author": "",
  "license": "ISC",
  "devDependencies": {
    "@types/node": "^25.3.3",
    "@types/ws": "^8.18.1",
    "@typescript-eslint/eslint-plugin": "^8.56.1",
    "@typescript-eslint/parser": "^8.56.1",
    "@vitest/coverage-v8": "^4.0.18",
    "eslint": "^10.0.2",
    "prettier": "^3.8.1",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18",
    "zod": "^4.3.6"
  },
  "dependencies": {
    "@mariozechner/pi-ai": "^0.55.3",
    "@tobilu/qmd": "^1.0.7",
    "undici": "^7.22.0",
    "ws": "^8.19.0"
  }
}
