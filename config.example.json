{
  "system": {
    "logLevel": "info",
    "workspacePath": "./workspace"
  },
  "model": {
    "defaultProvider": "ollama",
    "timeout": 30000,
    "maxRetries": 3,
    "retryBaseDelay": 1000,
    "providers": {
      "ollama": {
        "type": "openai-compatible",
        "apiKey": "ollama",
        "baseUrl": "http://localhost:11434/v1",
        "defaultModel": "llama3",
        "models": ["llama3", "qwen2.5", "deepseek-r1"]
      },
      "anthropic": {
        "type": "anthropic",
        "apiKey": "your-anthropic-api-key",
        "defaultModel": "claude-sonnet-4-20250514",
        "models": ["claude-opus-4-20250514", "claude-sonnet-4-20250514", "claude-haiku-4-5-20251001"]
      },
      "openai": {
        "type": "openai",
        "apiKey": "your-openai-api-key",
        "defaultModel": "gpt-4o",
        "models": ["gpt-4o", "gpt-4o-mini", "gpt-4.1", "gpt-4.1-mini"]
      },
      "google": {
        "type": "google",
        "apiKey": "your-google-api-key",
        "defaultModel": "gemini-2.0-flash",
        "models": ["gemini-2.0-flash", "gemini-2.5-pro"]
      },
      "groq": {
        "type": "groq",
        "apiKey": "your-groq-api-key",
        "defaultModel": "llama-3.3-70b-versatile",
        "models": ["llama-3.3-70b-versatile", "mixtral-8x7b-32768"]
      }
    }
  },
  "tools": {
    "defaultTimeout": 30000,
    "defaultMaxRetries": 0,
    "codeGenerationProvider": "ollama",
    "codeGenerationModel": "llama3"
  },
  "react": {
    "maxIterations": 20,
    "stepTimeout": 60000,
    "parallelToolCalls": true,
    "compressionThreshold": 10
  },
  "memory": {
    "shortTerm": true,
    "longTerm": true,
    "hotSessionMaxTokens": 4000
  },
  "agents": {
    "defaultMaxTurns": 50,
    "knowledgeMaxTokens": 8000
  },
  "superAgents": {
    "defaultMaxDuration": 600,
    "maxParallelAgents": 5
  },
  "self": {
    "focusLevel": 60,
    "cautionLevel": 50,
    "creativityLevel": 50
  },
  "inspector": {
    "enabled": true,
    "checkInterval": 180000,
    "loopDetectionThreshold": 3,
    "maxRetryThreshold": 5,
    "minAvailableMemoryMB": 100,
    "maxExecutionTimeSecs": 3600
  },
  "reflection": {
    "enabled": true,
    "minSkillConfidence": 0.7
  },
  "api": {
    "port": 3000,
    "host": "127.0.0.1",
    "apiKey": "",
    "rateLimitWindowMs": 60000,
    "rateLimitMaxRequests": 60,
    "corsOrigin": "*"
  },
  "persistence": {
    "enabled": true,
    "checkpointIntervalMs": 60000,
    "snapshotDir": "state",
    "enableAutoRecovery": true,
    "recoveryTTLSecs": 86400,
    "maxSnapshots": 10
  }
}
