{
  "system": {
    "logLevel": "info",
    "proxy": "",
    "api": {
      "port": 3000,
      "host": "127.0.0.1",
      "apiKey": "",
      "rateLimitWindowMs": 60000,
      "rateLimitMaxRequests": 60,
      "corsOrigin": "*",
      "staticDir": ""
    },
    "model": {
      "timeout": 30000,
      "maxRetries": 3,
      "retryBaseDelay": 1000
    },
    "tool": {
      "defaultTimeout": 30000,
      "defaultMaxRetries": 0,
      "codeGenerationProvider": "",
      "codeGenerationModel": ""
    },
    "react": {
      "maxIterations": 20,
      "stepTimeout": 60000,
      "parallelToolCalls": true,
      "compressionThreshold": 10
    },
    "memory": {
      "shortTerm": true,
      "longTerm": true,
      "hotSessionMaxTokens": 4000
    },
    "self": {
      "focusLevel": 60,
      "cautionLevel": 50,
      "creativityLevel": 50
    },
    "inspector": {
      "enabled": true,
      "checkInterval": 180000,
      "loopDetectionThreshold": 3,
      "maxRetryThreshold": 5,
      "minAvailableMemoryMB": 100,
      "maxExecutionTimeSecs": 3600
    },
    "reflection": {
      "enabled": true,
      "minSkillConfidence": 0.7
    }
  },
  "provider": {
    "ollama": {
      "type": "openai-compatible",
      "apiKey": "ollama",
      "baseUrl": "http://localhost:11434/v1",
      "defaultModel": "llama3",
      "models": ["llama3", "qwen3:32b"]
    },
    "openai": {
      "type": "openai",
      "apiKey": "${OPENAI_API_KEY}",
      "defaultModel": "gpt-4o",
      "models": [
        {
          "id": "gpt-4o",
          "name": "GPT-4o",
          "reasoning": false,
          "input": ["text", "image"],
          "cost": { "input": 2.5, "output": 10, "cacheRead": 0, "cacheWrite": 0 },
          "contextWindow": 128000,
          "maxTokens": 16384
        }
      ]
    },
    "anthropic": {
      "type": "anthropic",
      "defaultModel": "claude-sonnet-4-20250514"
    }
  },
  "agents": {
    "default": {
      "model": "ollama/llama3",
      "workspacePath": "./workspace",
      "maxTurns": 50,
      "thinkLevel": "medium",
      "knowledgeMaxTokens": 8000
    }
  },
  "tools": {
    "web": {
      "search": {
        "enabled": true,
        "provider": "bing",
        "maxResults": 5,
        "timeoutSeconds": 30
      },
      "fetch": {
        "enabled": true
      }
    }
  },
  "channels": {
    "web": {
      "enabled": true,
      "port": 8517,
      "host": "127.0.0.1"
    },
    "tui": {
      "enabled": true
    },
    "telegram": {
      "enabled": false,
      "dmPolicy": "pairing",
      "groupPolicy": "allowlist",
      "streaming": "partial"
    }
  },
  "persistence": {
    "enabled": true,
    "checkpointIntervalMs": 60000,
    "snapshotDir": "state",
    "enableAutoRecovery": true,
    "recoveryTTLSecs": 86400,
    "maxSnapshots": 10
  }
}
