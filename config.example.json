{
  "system": {
    "logLevel": "info",
    "workspacePath": "./workspace"
  },
  "model": {
    "defaultProvider": "ollama",
    "timeout": 30000,
    "maxRetries": 3,
    "retryBaseDelay": 1000,
    "providers": {
      "ollama": {
        "type": "openai-compatible",
        "apiKey": "ollama",
        "baseUrl": "http://localhost:11434/v1",
        "defaultModel": "llama3"
      },
      "anthropic": {
        "type": "anthropic",
        "apiKey": "your-anthropic-api-key",
        "defaultModel": "claude-sonnet-4-20250514"
      },
      "openai": {
        "type": "openai",
        "apiKey": "your-openai-api-key",
        "defaultModel": "gpt-4o"
      }
    }
  }
}
